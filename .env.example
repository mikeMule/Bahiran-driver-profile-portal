# Copy to .env and fill in your values
# Supabase: use Session pooler (IPv4-friendly). Get URI from Dashboard → Connect → Session mode
# Or direct: postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres (encode password: @=%40 !=%21 $=%24)
SUPABASE_DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres
# Optional fallback if first URL fails (e.g. DNS): paste Session pooler URI from dashboard
# SUPABASE_DATABASE_POOLER_URL=postgresql://...
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_publishable_key
SUPABASE_ANON_KEY=your_anon_key

# Optional: Google Drive — use a folder inside a Shared Drive (service accounts have no "My Drive" quota)
# Create Shared Drive → add service account as member → use folder ID below
# GOOGLE_DRIVE_CREDENTIALS=./service-account-drive.json
# GOOGLE_DRIVE_FOLDER_ID=folder_id_inside_shared_drive
